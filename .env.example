# Supabase (Server-side per RAG e salvataggi)
SUPABASE_URL=https://tuo-progetto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tuo-service-role-key

# Supabase (Client-side per auth)
SUPABASE_KEY=tuo-anon-public-key

# API per AI provider (default: OpenRouter OpenAI-compatible)
# AI_API_URL=https://openrouter.ai/api/v1/chat/completions
# AI_MODEL=deepseek/deepseek-chat
AI_API_KEY=sk-or-v1-tua-chiave-openrouter
# Fallback: BLUESMINDS_API_KEY e' ancora supportato
# BLUESMINDS_API_KEY=tuo-api-key-bluesminds

# Groq Whisper per trascrizione vocale (gratis, no carta di credito)
# 1. Vai su https://console.groq.com → API Keys → Crea chiave
# 2. Copia la chiave qui sotto
# 3. Deploy su Vercel
GROQ_API_KEY=gsk_tua-chiave-groq